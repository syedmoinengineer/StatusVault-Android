<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="180dp">

        <!-- Thumbnail -->
        <ImageView
            android:id="@+id/ivThumbnail"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="@color/placeholder_color" />

        <!-- Bottom gradient overlay -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/gradient_overlay" />

        <!-- Play icon (video only) -->
        <ImageView
            android:id="@+id/ivPlayOverlay"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_play_circle"
            android:visibility="gone"
            app:tint="#FFFFFF" />

        <!-- Duration badge (video only) -->
        <TextView
            android:id="@+id/tvDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|start"
            android:layout_margin="8dp"
            android:background="@drawable/bg_badge"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:text="0:00"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- Saved check badge (top-end) -->
        <ImageView
            android:id="@+id/ivSavedBadge"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="top|end"
            android:layout_margin="6dp"
            android:src="@drawable/ic_check_circle"
            android:visibility="gone"
            app:tint="@color/green_saved" />

        <!-- ✅ FIX: Bottom action row — Save button + Share icon button, properly aligned -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="8dp">

            <!-- Save button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:layout_marginEnd="6dp"
                android:text="@string/save"
                android:textSize="11sp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="8dp"
                app:icon="@drawable/ic_download"
                app:iconSize="13dp"
                app:iconPadding="4dp"
                style="@style/Widget.Material3.Button.ElevatedButton" />

            <!-- ✅ Share button: plain ImageButton with tonal background, icon perfectly centered -->
            <ImageButton
                android:id="@+id/btnShare"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:src="@drawable/ic_share"
                android:padding="7dp"
                android:scaleType="fitCenter"
                android:background="@drawable/bg_share_btn"
                android:contentDescription="Share"
                app:tint="?attr/colorOnSecondaryContainer" />

        </LinearLayout>

    </FrameLayout>

</com.google.android.material.card.MaterialCardView>